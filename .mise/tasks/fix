#!/usr/bin/env bash
#MISE description="Run pre-commit hooks to fix files"
#USAGE arg "[files]" var=#true help="Specific files to fix (default: all files)"

set -euo pipefail

eval "files=(${usage_files:-})"
if [ ${#files[@]} -gt 0 ]; then
  hk run pre-commit "${files[@]}"
else
  hk run pre-commit --all
fi
